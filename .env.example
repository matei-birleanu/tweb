# Database Configuration
POSTGRES_DB=shop_db
POSTGRES_USER=shop_user
POSTGRES_PASSWORD=shop_pass123

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Keycloak Configuration
Keycloak__Authority=http://localhost:8180/realms/shop-platform
Keycloak__Audience=shop-client
Keycloak__RequireHttpsMetadata=false

# Database Connection Strings
ConnectionStrings__DefaultConnection=Host=localhost;Database=shop_db;Username=shop_user;Password=shop_pass123

# Stripe Payment Configuration
Stripe__SecretKey=sk_test_your_stripe_secret_key
Stripe__PublishableKey=pk_test_your_stripe_publishable_key
Stripe__WebhookSecret=whsec_your_webhook_secret

# Elasticsearch Configuration
Elasticsearch__Uri=http://localhost:9200
Elasticsearch__DefaultIndex=shop-products

# Email Configuration (Mailtrap for development)
Email__Host=smtp.mailtrap.io
Email__Port=2525
Email__Username=your_mailtrap_username
Email__Password=your_mailtrap_password
Email__FromEmail=noreply@shop-platform.com
Email__FromName=Shop Platform

# JWT Configuration
Jwt__Secret=your-super-secret-jwt-key-change-this-in-production
Jwt__Issuer=https://shop-platform.com
Jwt__Audience=shop-client
Jwt__ExpirationMinutes=60

# CORS Configuration
Cors__AllowedOrigins=http://localhost:3000,http://localhost:3001

# File Upload Configuration
FileUpload__MaxFileSize=10485760
FileUpload__AllowedExtensions=.jpg,.jpeg,.png,.gif,.webp
FileUpload__StoragePath=/uploads

# Logging Configuration
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning
Logging__LogLevel__System=Warning

# Redis Configuration (for caching - optional)
Redis__ConnectionString=localhost:6379
Redis__InstanceName=ShopPlatform

# Application Insights (Azure - optional)
ApplicationInsights__InstrumentationKey=your-instrumentation-key

# Frontend Environment Variables
REACT_APP_API_URL=http://localhost:8080
REACT_APP_KEYCLOAK_URL=http://localhost:8180
REACT_APP_KEYCLOAK_REALM=shop-platform
REACT_APP_KEYCLOAK_CLIENT_ID=shop-client
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Feature Flags
Features__EnableElasticsearch=true
Features__EnablePayments=true
Features__EnableEmailNotifications=true
Features__EnableImageOptimization=true

# Rate Limiting
RateLimit__PermitLimit=100
RateLimit__Window=60
RateLimit__QueueLimit=10
